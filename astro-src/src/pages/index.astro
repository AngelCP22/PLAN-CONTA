---
import Header from "../components/Header.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site, waLink } from "../data/site";

const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();

const services = [
  ["Gestión contable", "Registro de operaciones, conciliaciones, análisis de cuentas y estados financieros claros.", "contable"],
  ["Gestión laboral", "Altas, bajas, planillas, beneficios sociales y soporte documental laboral.", "laboral"],
  ["Gestión tributaria", "Declaraciones de IGV y renta, libros electrónicos y seguimiento de obligaciones ante SUNAT.", "tributaria"],
  ["Comercio exterior", "Drawback, saldo a favor del exportador y control documentario para tus operaciones de exportación.", "comercio"],
];

const plans = [
  {
    name: "Plan Emprende",
    title: "Para formalizar y empezar bien",
    text: "Ideal para negocios nuevos que necesitan orden tributario básico y una ruta clara de cumplimiento.",
    items: ["Orientación de régimen tributario.", "Calendario de obligaciones iniciales.", "Orden documentario y comprobantes.", "Declaraciones mensuales esenciales."],
  },
  {
    name: "Plan Negocio",
    title: "Para operar con control mensual",
    text: "Para empresas en marcha que requieren gestión contable, tributaria y seguimiento permanente.",
    items: ["Registro de compras, ventas y operaciones.", "Declaraciones de IGV, renta y libros electrónicos.", "Conciliaciones y reportes mensuales.", "Alertas ante inconsistencias o vencimientos."],
    featured: true,
  },
  {
    name: "Plan Premium",
    title: "Para crecer con mirada estratégica",
    text: "Para empresas que necesitan control integral, prevención tributaria y lectura financiera para decidir.",
    items: ["Diagnóstico preventivo de riesgos.", "Gestión contable, tributaria y laboral integral.", "Indicadores de gestión y reuniones periódicas.", "Acompañamiento en fiscalizaciones o requerimientos."],
  },
];

// Resultados anonimizados por la Ley N° 29733 (Protección de Datos Personales):
// se describe el rubro del cliente en vez de su razón social / nombre. Si cuentas
// con consentimiento escrito del cliente, puedes reemplazar por el nombre real.
const results = [
  ["Empresa de perforación geotécnica", "Conciliaciones y registros ordenados", "Se estructuró el flujo mensual de documentos para reducir reprocesos y mejorar la trazabilidad.", "Resultado: cierres mensuales más claros."],
  ["Consultora de geología y minería", "Compras y ventas con mejor sustento", "Se revisó la consistencia de comprobantes y registros para presentar información más confiable.", "Resultado: menor exposición a observaciones."],
  ["Empresa de ingeniería geotécnica", "Obligaciones mensuales monitoreadas", "Se organizaron pendientes y fechas clave para dar seguimiento continuo a declaraciones y libros.", "Resultado: calendario tributario siempre visible."],
  ["Profesional independiente (sector minero)", "Información centralizada para consultas", "Se concentró la documentación clave para facilitar declaraciones, respuestas y control interno.", "Resultado: soporte documentario disponible."],
];

const stats = [
  ["15+", "años de experiencia"],
  ["749", "clientes asesorados"],
  ["7", "especialistas aliados"],
  ["9", "áreas de servicio"],
  ["371", "procesos estructurados"],
];
---

<BaseLayout>
  <Header />
  <main id="contenido" tabindex="-1">
    <section class="hero" id="inicio">
      <picture class="hero-bg" aria-hidden="true">
        <source srcset={`${base}assets/hero-bg.webp`} type="image/webp" />
        <img src={`${base}assets/hero-bg.jpg`} alt="" width="1600" height="1000" fetchpriority="high" decoding="async" />
      </picture>
      <div class="hero-overlay" aria-hidden="true"></div>
      <div class="container hero-grid">
        <div class="hero-copy reveal-card from-left">
          <p class="eyebrow">Asesoría empresarial estratégica</p>
          <h1>Soluciones contables y tributarias para tu empresa</h1>
          <p>Ordenamos tu información contable, cumplimos tus obligaciones a tiempo y te damos números claros para tomar mejores decisiones.</p>
          <div class="actions">
            <a class="button gold" href="#contacto">Solicitar asesoría</a>
            <a class="button ghost" href="#servicios">Ver servicios</a>
          </div>
          <ul class="chips">
            <li>Cumplimiento SUNAT</li>
            <li>Libros electrónicos</li>
            <li>Exportadores y drawback</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="section" id="nosotros">
      <div class="container split">
        <div class="reveal-card from-left">
          <p class="eyebrow">Quiénes somos</p>
          <h2>Tu aliado estratégico empresarial.</h2>
          <p>En M&R Asociados ordenamos la información contable, tributaria y laboral para que tu empresa tenga claridad, cumpla a tiempo y reduzca riesgos.</p>
        </div>
        <div class="feature-grid reveal-sequence" id="propositos">
          <article class="reveal-card from-bottom"><span>01</span><strong>Cálculos exactos</strong></article>
          <article class="reveal-card from-bottom"><span>02</span><strong>Cumplimiento normativo</strong></article>
          <article class="reveal-card from-bottom"><span>03</span><strong>Claridad financiera</strong></article>
          <article class="reveal-card from-bottom"><span>04</span><strong>Prevención tributaria</strong></article>
        </div>
      </div>
    </section>

    <section class="section light" id="proceso">
      <div class="container">
        <div class="section-head left reveal-card from-left">
          <p class="eyebrow">Proceso de trabajo</p>
          <h2>Una metodología clara para pasar del desorden al control.</h2>
          <p>Cada etapa está pensada para entender la situación actual, ordenar la información y sostener el cumplimiento sin improvisar.</p>
        </div>
        <div class="steps reveal-sequence">
          <article class="reveal-card from-bottom"><span>01</span><h3>Diagnóstico inicial</h3><p>Revisión del régimen, documentos, obligaciones pendientes y riesgos visibles.</p></article>
          <article class="reveal-card from-bottom"><span>02</span><h3>Plan de orden</h3><p>Prioridades, fechas, responsables y entregables para cada área.</p></article>
          <article class="reveal-card from-bottom"><span>03</span><h3>Ejecución mensual</h3><p>Registros, declaraciones, planillas, conciliaciones y reportes.</p></article>
          <article class="reveal-card from-bottom"><span>04</span><h3>Seguimiento preventivo</h3><p>Alertas, revisión de inconsistencias y acompañamiento en decisiones.</p></article>
        </div>
      </div>
    </section>

    <section class="section export" id="exportacion">
      <div class="container export-grid">
        <div class="reveal-card from-left">
          <p class="eyebrow">Exportación y drawback</p>
          <h2>Soporte contable y tributario para empresas exportadoras.</h2>
          <p>Integramos contabilidad, documentación de comercio exterior y beneficios tributarios para que tu empresa cuente con sustento claro antes de solicitar o responder ante SUNAT.</p>
        </div>
        <div class="export-cards reveal-sequence">
          <article class="reveal-card from-right"><h3>Drawback</h3><p>Revisión de DAM/DUA, insumos, compras vinculadas y documentación exigida para sustentar solicitudes.</p></article>
          <article class="reveal-card from-right"><h3>Saldo a favor del exportador</h3><p>Control de compras, ventas e IGV, con soporte para gestionar el beneficio cuando corresponda.</p></article>
          <article class="reveal-card from-right"><h3>PDB Exportadores</h3><p>Preparación y consistencia de la información para presentar beneficios con menor riesgo de observaciones.</p></article>
        </div>
      </div>
    </section>

    <section class="section" id="servicios">
      <div class="container">
        <div class="section-head left reveal-card from-left">
          <p class="eyebrow">Servicios</p>
          <h2>Gestión integral para reducir riesgos y ordenar tu operación.</h2>
        </div>
        <div class="cards reveal-sequence">
          {services.map(([title, text, img], index) => (
            <article class:list={["service-card", "reveal-card", index % 2 === 0 ? "from-bottom" : "from-right"]}>
              <div class="service-media">
                <img src={`${base}assets/servicios/${img}.jpg`} alt={`${title} — M&R Asociados`} width="900" height="650" loading="lazy" decoding="async" />
              </div>
              <div class="service-body">
                <h3>{title}</h3>
                <p>{text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section plans" id="planes">
      <div class="container">
        <div class="section-head reveal-card from-bottom">
          <p class="eyebrow">Planes de acompañamiento</p>
          <h2>Elige el soporte según el momento de tu empresa.</h2>
          <p>Planes comparables por etapa, alcance y nivel de complejidad. Se ajustan luego del diagnóstico inicial.</p>
        </div>
        <div class="plan-grid reveal-sequence">
          {plans.map((plan, index) => (
            <article class:list={["plan", "reveal-card", index === 0 ? "from-left" : index === 1 ? "from-bottom" : "from-right", { featured: plan.featured }]}>
              {plan.featured && <div class="badge">Más solicitado</div>}
              <span>{plan.name}</span>
              <h3>{plan.title}</h3>
              <p>{plan.text}</p>
              <ul>{plan.items.map((item) => <li>{item}</li>)}</ul>
              <a href="#contacto">Solicitar asesoría</a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section" id="resultados">
      <div class="container">
        <div class="section-head left reveal-card from-left">
          <p class="eyebrow">Resultados obtenidos</p>
          <h2>Empresas acompañadas con problemas concretos resueltos.</h2>
          <p>Mejoras verificables: información ordenada, obligaciones bajo control y criterios claros para responder ante SUNAT.</p>
        </div>
        <div class="impact-grid reveal-sequence">
          {results.map(([company, title, text, solution], index) => (
            <article class:list={["reveal-card", index % 2 === 0 ? "from-bottom" : "from-right"]}><span>{company}</span><h3>{title}</h3><p>{text}</p><strong>{solution}</strong></article>
          ))}
        </div>
      </div>
    </section>

    <section class="section contact" id="contacto">
      <div class="container contact-card reveal-card from-bottom">
        <p class="eyebrow">Contacto</p>
        <h2>¿Listo para ordenar tu gestión contable y tributaria?</h2>
        <p>Escríbenos y solicita una asesoría para revisar la situación actual de tu empresa. Te respondemos por WhatsApp.</p>
        <a class="button gold contact-cta" href={waLink()} target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 32 32" width="22" height="22" fill="currentColor" aria-hidden="true"><path d="M16.04 4.5c-6.35 0-11.5 5.08-11.5 11.34 0 2 .53 3.95 1.55 5.67L4.5 27.5l6.18-1.6a11.66 11.66 0 0 0 5.36 1.3c6.35 0 11.5-5.08 11.5-11.35 0-3.03-1.2-5.88-3.37-8.02a11.56 11.56 0 0 0-8.13-3.33Zm0 2.17c2.5 0 4.84.96 6.6 2.7a9.02 9.02 0 0 1 2.74 6.48c0 5.06-4.2 9.18-9.34 9.18-1.6 0-3.17-.4-4.55-1.18l-.5-.28-3.67.95.98-3.52-.32-.52a9.04 9.04 0 0 1-1.4-4.86c0-5.06 4.2-9.18 9.34-9.18Zm-4.1 4.4c-.2 0-.5.07-.77.36-.26.3-1 .98-1 2.4 0 1.4 1.03 2.77 1.17 2.96.14.19 2 3.16 4.93 4.3 2.44.95 2.94.76 3.47.71.53-.05 1.7-.69 1.94-1.36.24-.66.24-1.24.17-1.36-.07-.12-.26-.19-.55-.33-.29-.14-1.7-.83-1.96-.92-.26-.1-.46-.15-.65.14-.19.29-.74.92-.9 1.1-.17.2-.34.22-.62.08a7.84 7.84 0 0 1-2.31-1.41 8.55 8.55 0 0 1-1.6-1.97c-.17-.29-.02-.44.13-.58.13-.13.28-.34.43-.5.14-.18.19-.3.29-.5.1-.18.05-.36-.02-.5-.07-.14-.64-1.54-.88-2.1-.23-.56-.47-.49-.65-.5l-.62-.02Z"/></svg>
          Enviar por WhatsApp
        </a>
        <div class="contact-pills"><a href={`tel:${site.telefonoTel}`}>{site.telefonoDisplay}</a><span>{site.ciudad}</span></div>
      </div>
    </section>

    <section class="stats-band" id="metricas">
      <div class="stats-bg" style={`background-image: linear-gradient(90deg, rgba(6,20,38,.96), rgba(6,20,38,.72)), url('${base}assets/about.jpg');`} aria-hidden="true"></div>
      <div class="container stats-grid">
        <div class="stats-copy reveal-card from-left">
          <p class="eyebrow">Métricas de confianza</p>
          <h2>Más de 15 años de experiencia</h2>
          <p>Números que resumen trayectoria, capacidad de atención y amplitud de servicios para empresas que necesitan respaldo profesional.</p>
        </div>
        <div class="stats-numbers">
          {stats.map(([number, label], index) => (
            <article class:list={["reveal-card", index % 2 === 0 ? "from-right" : "from-bottom"]}>
              <strong data-count={number}>{number}</strong>
              <span>{label}</span>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-grid reveal-sequence">
      <a class="brand reveal-card from-bottom" href="#inicio">
        <img src={`${base}assets/logo-mark.png`} alt="Logo M&R Asociados" width="42" height="42" loading="lazy" />
        <span><strong>M&amp;R Asociados</strong><small>Gestión contable, tributaria y laboral</small></span>
      </a>
      <div class="reveal-card from-bottom"><strong>Servicios</strong><a href="#servicios">Gestión contable</a><a href="#exportacion">Drawback y exportación</a><a href="#planes">Planes</a></div>
      <div class="reveal-card from-bottom"><strong>Contacto</strong><a href={`tel:${site.telefonoTel}`}>956-308-249</a><a href={`https://wa.me/${site.whatsapp}`} target="_blank" rel="noopener noreferrer">WhatsApp directo</a></div>
    </div>
    <div class="container footer-bottom"><span>© {year} M&amp;R Asociados. Todos los derechos reservados.</span><span><a href={`${base}privacidad/`}>Política de privacidad</a> · {site.ciudad} · Atención a empresas de todo el país.</span></div>
  </footer>

  <a class="wa-float" href={waLink()} target="_blank" rel="noopener noreferrer" aria-label="Escríbenos por WhatsApp">
    <svg viewBox="0 0 32 32" width="26" height="26" fill="currentColor" aria-hidden="true"><path d="M16.04 4.5c-6.35 0-11.5 5.08-11.5 11.34 0 2 .53 3.95 1.55 5.67L4.5 27.5l6.18-1.6a11.66 11.66 0 0 0 5.36 1.3c6.35 0 11.5-5.08 11.5-11.35 0-3.03-1.2-5.88-3.37-8.02a11.56 11.56 0 0 0-8.13-3.33Zm0 2.17c2.5 0 4.84.96 6.6 2.7a9.02 9.02 0 0 1 2.74 6.48c0 5.06-4.2 9.18-9.34 9.18-1.6 0-3.17-.4-4.55-1.18l-.5-.28-3.67.95.98-3.52-.32-.52a9.04 9.04 0 0 1-1.4-4.86c0-5.06 4.2-9.18 9.34-9.18Zm-4.1 4.4c-.2 0-.5.07-.77.36-.26.3-1 .98-1 2.4 0 1.4 1.03 2.77 1.17 2.96.14.19 2 3.16 4.93 4.3 2.44.95 2.94.76 3.47.71.53-.05 1.7-.69 1.94-1.36.24-.66.24-1.24.17-1.36-.07-.12-.26-.19-.55-.33-.29-.14-1.7-.83-1.96-.92-.26-.1-.46-.15-.65.14-.19.29-.74.92-.9 1.1-.17.2-.34.22-.62.08a7.84 7.84 0 0 1-2.31-1.41 8.55 8.55 0 0 1-1.6-1.97c-.17-.29-.02-.44.13-.58.13-.13.28-.34.43-.5.14-.18.19-.3.29-.5.1-.18.05-.36-.02-.5-.07-.14-.64-1.54-.88-2.1-.23-.56-.47-.49-.65-.5l-.62-.02Z"/></svg>
  </a>

  <button class="to-top" type="button" aria-label="Volver arriba" data-to-top>
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
  </button>
</BaseLayout>

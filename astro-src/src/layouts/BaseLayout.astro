---
import "../styles/global.css";
import { site as siteData } from "../data/site";

const {
  title = `${siteData.nombre} | Gestión contable, tributaria y laboral`,
  description = siteData.descripcion,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(`${base}assets/og-image.jpg`, Astro.site).toString();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; base-uri 'self'; form-action 'self'; object-src 'none'"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#061426" />
    <link rel="canonical" href={canonical} />

    {/* Open Graph + Twitter para vistas previas en redes */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_PE" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" href={`${base}assets/logo-mark.png`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Playfair+Display:wght@700;800&display=swap"
      rel="stylesheet"
    />

    {/* Activa las animaciones solo si hay JS; sin JS el contenido es visible. */}
    <script is:inline>document.documentElement.classList.add("is-enhanced");</script>

    {/* Datos estructurados de negocio local para buscadores */}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "AccountingService",
      name: siteData.nombre,
      areaServed: "Perú",
      telephone: siteData.telefonoDisplay,
      url: canonical,
      image: ogImage,
      serviceType: [
        "Gestión contable",
        "Gestión tributaria",
        "Gestión laboral",
        "Drawback",
        "Contabilidad para exportadores",
      ],
    })} />
  </head>
  <body>
    <a class="skip-link" href="#contenido">Saltar al contenido</a>
    <slot />

    <script>
      import { initMenu } from "../scripts/menu";
      import { initHeaderShadow } from "../scripts/header-shadow";
      import { initScrollspy } from "../scripts/scrollspy";
      import { initWhatsappForms } from "../scripts/whatsapp-form";
      import { initToTop } from "../scripts/to-top";
      import { initLimaClock } from "../scripts/lima-clock";
      import { initReveal } from "../scripts/reveal";

      // Cada característica se inicializa de forma aislada: si una falla, las
      // demás siguen funcionando y el contenido nunca queda oculto.
      const safe = (fn: () => void) => {
        try {
          fn();
        } catch (error) {
          console.error("[M&R] init falló:", error);
        }
      };

      safe(initReveal); // primero: garantiza que el contenido se muestre
      safe(initMenu);
      safe(initHeaderShadow);
      safe(initScrollspy);
      safe(initWhatsappForms);
      safe(initToTop);
      safe(initLimaClock);
    </script>
  </body>
</html>

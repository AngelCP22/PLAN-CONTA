---
import { site, waLink } from "../data/site";

const base = import.meta.env.BASE_URL;
const navItems: [string, string][] = [
  ["Nosotros", "#nosotros"],
  ["Servicios", "#servicios"],
  ["Planes", "#planes"],
  ["Contacto", "#contacto"],
];
---

<header class="site-header" data-header>
  <div class="container nav">
    <a class="brand" href="#inicio" aria-label="Ir al inicio">
      <img src={`${base}assets/logo-mark.png`} alt={`Logo ${site.nombre}`} width="42" height="42" />
      <span>
        <strong>M&amp;R Asociados</strong>
        <small>Gestión contable, tributaria y laboral</small>
      </span>
    </a>
    <button class="menu-button" type="button" aria-label="Abrir menú" aria-expanded="false" aria-controls="menu-principal" data-menu-button>
      <span></span><span></span><span></span>
    </button>
    <nav class="menu" id="menu-principal" aria-label="Navegación principal" data-menu>
      {navItems.map(([label, href]) => <a href={href} data-nav-link>{label}</a>)}
      <a class="button gold" href={waLink()} target="_blank" rel="noopener noreferrer">Solicitar asesoría</a>
    </nav>
  </div>
</header>

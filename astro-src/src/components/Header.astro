---
const navItems = [
  ["Nosotros", "#nosotros"],
  ["Propósitos", "#propositos"],
  ["Proceso", "#proceso"],
  ["Exportación", "#exportacion"],
  ["Servicios", "#servicios"],
  ["Planes", "#planes"],
  ["Resultados", "#resultados"],
  ["Contacto", "#contacto"],
];
---

<header class="site-header">
  <div class="container nav">
    <a class="brand" href="#inicio" aria-label="Ir al inicio">
      <img src={`${import.meta.env.BASE_URL}assets/logo-mark.png`} alt="Logo M&R Asociados" width="42" height="42" />
      <span>
        <strong>M&amp;R Asociados</strong>
        <small>Gestión contable, tributaria y laboral</small>
      </span>
    </a>
    <button class="menu-button" type="button" aria-label="Abrir menú" data-menu-button>
      <span></span><span></span><span></span>
    </button>
    <nav class="menu" data-menu>
      {navItems.map(([label, href]) => <a href={href}>{label}</a>)}
      <a class="button gold" href="https://wa.me/51956308249?text=Hola%20M%26R%20Asociados%2C%20quiero%20solicitar%20una%20asesor%C3%ADa" target="_blank" rel="noreferrer">Solicitar asesoría</a>
    </nav>
  </div>
</header>
